# =========================================
# LLM
# =========================================

LLM_GROQ_API_KEY=your_groq_api_key

LLM_MODEL=llama-3.1-70b-versatile

LLM_TEMPERATURE=0.1


# =========================================
# TABLEAU
# =========================================

TABLEAU_URL=https://your-dashboard-url

TABLEAU_HEADLESS=true

TABLEAU_INITIAL_WAIT=10000

TABLEAU_FILTER_WAIT=2000

TABLEAU_POST_FILTER_WAIT=5000


# =========================================
# DATABASE
# =========================================

DB_URL=sqlite:///validateai.db


# =========================================
# LOGGING
# =========================================

LOG_LEVEL=INFO